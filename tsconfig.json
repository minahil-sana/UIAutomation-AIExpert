{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@ui/*": [
        "./main/ui/*"
      ],
      "@tests/*": [
        "./tests/*"
      ],
      "@test_data/*": [
        "./main/test_data/*"
      ],
      "@utils/*": [
        "./main/utils/*"
      ]

    },
    "types": [
      "node",
      "@playwright/test"
    ]
  },
  "include": [
    "main/**/*.ts",
    "test_data/**/*.json",
    "tests/**/*.ts",
    "playwright.config.ts"
  ]
}